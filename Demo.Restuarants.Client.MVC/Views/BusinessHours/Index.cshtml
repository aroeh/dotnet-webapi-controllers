@model List<Demo.Restuarants.Shared.Models.RestuarantBusinessHourBO>
@{
    ViewData["Title"] = "Business Hours";
    var restuarantId = (string)ViewBag.RestuarantId;
    var restuarantName = ViewBag.RestuarantName as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Business Hours</h1>
        @if (!string.IsNullOrWhiteSpace(restuarantName))
        {
            <p class="text-muted mb-0">@restuarantName</p>
        }
    </div>
    <a class="btn btn-primary" asp-action="Create" asp-route-restuarantId="@restuarantId">Add Entry</a>
</div>

<partial name="_Alerts" />

@if (Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Day</th>
                    <th>Open</th>
                    <th>Close</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hour in Model.OrderBy(h => h.DayOfWeek))
                {
                    <tr>
                        <td>@hour.DayOfWeek</td>
                        <td>@hour.OpenTime.ToString("t")</td>
                        <td>@hour.CloseTime.ToString("t")</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary"
                               asp-action="Edit"
                               asp-route-restuarantId="@restuarantId"
                               asp-route-businessHourId="@hour.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger"
                               asp-action="Delete"
                               asp-route-restuarantId="@restuarantId"
                               asp-route-businessHourId="@hour.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-muted">No business hours entries found.</p>
}

<p class="mt-3">
    <a asp-controller="Restuarants" asp-action="Details" asp-route-id="@restuarantId">&larr; Back to restaurant</a>
</p>
