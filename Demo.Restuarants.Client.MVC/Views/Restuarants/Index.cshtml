@model Demo.Restuarants.Client.MVC.Models.RestuarantListViewModel
@{
    ViewData["Title"] = "Restaurants";
    var meta = Model.Results?.MetaData;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Restaurants</h1>
    <a class="btn btn-primary" asp-action="Create">Add Restaurant</a>
</div>

<partial name="_Alerts" />

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label asp-for="NameFilter" class="form-label">Name (comma-separated)</label>
                <input asp-for="NameFilter" class="form-control" placeholder="pizza, cookie" />
            </div>
            <div class="col-md-3">
                <label asp-for="CuisineFilter" class="form-label">Cuisine</label>
                <input asp-for="CuisineFilter" class="form-control" />
            </div>
            <div class="col-md-2">
                <label asp-for="Page" class="form-label">Page</label>
                <input asp-for="Page" class="form-control" type="number" min="1" />
            </div>
            <div class="col-md-2">
                <label asp-for="PageSize" class="form-label">Page Size</label>
                <input asp-for="PageSize" class="form-control" type="number" min="1" max="100" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-outline-primary w-100">Search</button>
            </div>
        </div>
    </div>
</form>

@if (Model.Results?.Data is not null && Model.Results.Data.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Cuisine</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results.Data)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.CuisineType</td>
                        <td>@item.Phone</td>
                        <td>@item.Address.City</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Details</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (meta is not null)
    {
        <div class="d-flex justify-content-between align-items-center">
            <p class="text-muted mb-0">
                Page @meta.CurrentPage of @meta.TotalPages (@meta.TotalRecords total)
            </p>
            <div class="btn-group">
                @if (Model.Page > 1)
                {
                    <a class="btn btn-outline-secondary"
                       asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-nameFilter="@Model.NameFilter"
                       asp-route-cuisineFilter="@Model.CuisineFilter">Previous</a>
                }
                @if (Model.Page < meta.TotalPages)
                {
                    <a class="btn btn-outline-secondary"
                       asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-nameFilter="@Model.NameFilter"
                       asp-route-cuisineFilter="@Model.CuisineFilter">Next</a>
                }
            </div>
        </div>
    }
}
else
{
    <p class="text-muted">No restaurants found.</p>
}
