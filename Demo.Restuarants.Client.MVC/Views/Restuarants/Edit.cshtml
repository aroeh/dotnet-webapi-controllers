@model Demo.Restuarants.Client.MVC.Models.RestuarantFormViewModel
@{
    ViewData["Title"] = "Edit Restaurant";
}

<h1>Edit Restaurant</h1>
<partial name="_Alerts" />

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="card">
    <div class="card-body">
        <partial name="_RestuarantForm" model="Model" />
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
